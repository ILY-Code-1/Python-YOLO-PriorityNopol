# ─── YOLO Training Output ────────────────────────────────────────────────────
runs/

dataset/_raw
# ─── Dataset (opsional: comment jika dataset kecil dan ingin di-commit) ──────
dataset/images/train/*
dataset/images/val/*
dataset/images/*.jpg
dataset/labels/train/*
dataset/labels/val/*
dataset/labels/*.cache
# Kecualikan .gitkeep agar struktur folder tetap ada di repo
!dataset/images/train/.gitkeep
!dataset/images/val/.gitkeep
!dataset/labels/train/.gitkeep
!dataset/labels/val/.gitkeep

